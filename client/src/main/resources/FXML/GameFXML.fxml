<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" 
     fx:id = "borderPane" styleClass="border" fx:controller = "GameController">

    <top><ToolBar>
        <MenuButton text="Options">
            <items>
                <MenuItem fx:id="freshStart" text="Fresh start"/>
                <MenuItem fx:id="newLook" text="New Look"/>
                <MenuItem fx:id="exit" text="Exit"/>
            </items>
        </MenuButton>
    </ToolBar></top>

    <left><VBox xmlns:fx="http://javafx.com/fxml/1" spacing="10" alignment="CENTER">
    
        <HBox xmlns:fx="http://javafx.com/fxml/1">
            <TextField fx:id = "A" Text="Ante" maxWidth= "120" editable= "false"/>
            <TextField fx:id="anteWager" promptText="Between 5 to 25" maxWidth="170"/>
        </HBox>


        <HBox xmlns:fx="http://javafx.com/fxml/1">
            <TextField fx:id = "PP" Text="Pair Plus" maxWidth= "120" editable= "false"/>
            <TextField fx:id="pairPlusWager" promptText="Between 5 to 25" maxWidth="170"/>
        </HBox>

        <HBox xmlns:fx="http://javafx.com/fxml/1">
            <TextField fx:id = "P" Text="Play" maxWidth= "120" editable= "false"/>
            <TextField fx:id = "playWager" promptText="Is equal to Ante" maxWidth= "170" editable = "false"/>
        </HBox>

        <HBox xmlns:fx="http://javafx.com/fxml/1">
            <TextField fx:id = "T" Text="Total Winning" maxWidth= "120" editable= "false"/>
            <TextField fx:id = "totalWinning" promptText="Total winning" maxWidth= "170" editable = "false"/>
        </HBox>

    </VBox></left>

    
    <center><VBox xmlns:fx="http://javafx.com/fxml/1" spacing="10" alignment="CENTER">
            
            <HBox xmlns:fx="http://javafx.com/fxml/1" spacing="10" alignment="CENTER">
                <ImageView fx:id="dealerCard1" fitWidth="100" fitHeight="175"/>
                <ImageView fx:id="dealerCard2" fitWidth="100" fitHeight="175"/>
                <ImageView fx:id="dealerCard3" fitWidth="100" fitHeight="175"/>
            </HBox>


            <VBox xmlns:fx="http://javafx.com/fxml/1" spacing="10" alignment="CENTER">

                <Button fx:id = "deal" text = "Deal"/>

                <HBox xmlns:fx="http://javafx.com/fxml/1" alignment="CENTER">
                    <Button fx:id = "play" text = "Play Hand" disable= "true"/>
                    <Button fx:id = "fold" text = "Fold Hand" disable= "true"/>
                </HBox>
            </VBox>

            <HBox xmlns:fx="http://javafx.com/fxml/1" spacing="10" alignment="CENTER">
                <ImageView fx:id="clientCard1" fitWidth="100" fitHeight="175"/>
                <ImageView fx:id="clientCard2" fitWidth="100" fitHeight="175"/>
                <ImageView fx:id="clientCard3" fitWidth="100" fitHeight="175"/>
            </HBox>
    

    </VBox></center>





    <right><VBox xmlns:fx="http://javafx.com/fxml/1" spacing="10" alignment="CENTER">
        <ListView fx:id="hist" maxWidth="250" maxHeight="250"/>
    </VBox></right>




</BorderPane>
